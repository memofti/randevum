NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Demo butonları göstermek için (sadece dev/staging) — prod'da set etmeyin
NEXT_PUBLIC_DEMO_ENABLED=false

# Web push için VAPID public key (npx web-push generate-vapid-keys ile üretildi)
# Private key Supabase Edge Function secret'larına VAPID_PRIVATE_KEY olarak konulmalı
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:memofti@gmail.com

# Resend email
RESEND_API_KEY=

# Sentry — sentry.io'dan proje açıp DSN al
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
